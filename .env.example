# === MeetingPi Configuration ===

# --- Audio ---
AUDIO_DEVICE=plughw:1,0          # Vérifier avec: arecord -l
RECORDINGS_DIR=/home/pi/recordings
KEEP_AUDIO=false                  # true = conserve le .wav après transcription

# --- Whisper.cpp ---
WHISPER_BIN=/home/pi/whisper.cpp/main
WHISPER_MODEL_PATH=/home/pi/whisper.cpp/models/ggml-model-tiny.en.q5_1.bin
WHISPER_THREADS=3
WHISPER_LANGUAGE=fr               # fr ou en

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini            # phi3:mini si 4GB RAM, llama3:8b si 8GB
SUMMARY_LANGUAGE=fr

# --- API ---
DATABASE_URL=sqlite:///./meetingpi.db
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend (copier dans crm-frontend/.env.local) ---
NEXT_PUBLIC_PI_API_URL=http://raspberrypi.local:8000
